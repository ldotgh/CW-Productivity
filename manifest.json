{
  "manifest_version": 3,
  "name": "CoreWeave Grafana Node Tabs",
  "version": "1.0",
  "description": "Rename and group Grafana Node Details tabs by node",
  "permissions": ["tabs", "tabGroups", "scripting"],
  "host_permissions": [
    "https://grafana.int.coreweave.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
